# Artemis - variables d'environnement (modèle). Copier en `.env` et compléter.

# Base de données PostgreSQL (Prisma)
DATABASE_URL="postgresql://tracker:tracker@localhost:5432/rakoon_tracker?schema=public"

# Auth.js
# Générer le secret : openssl rand -base64 32  - NE JAMAIS committer une vraie valeur.
# En production, l'application refuse de démarrer si AUTH_SECRET est absent.
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Sécurité - inscription restreinte à ces domaines e-mail (CSV). Vide/absent = ouverte (dev only).
ALLOWED_EMAIL_DOMAINS="rakoon.io"

# Stockage S3-compatible des pièces jointes (MinIO en local) - optionnel
# (la fonctionnalité se désactive proprement si non renseigné)
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="artemis-attachments"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_REGION="us-east-1"

# Serveur MCP (assistant IA) - compte de service au nom duquel l'IA agit sur
# les tickets. Doit exister en base et etre membre des projets concernes.
ARTEMIS_MCP_ACTOR_EMAIL="bot@rakoon.io"

# Notifications par e-mail (Mailjet) - optionnel : desactive si absent.
# Les concernes (rapporteur, assigne) recoivent un e-mail sur les evenements cles.
MAILJET_API_KEY=""
MAILJET_API_SECRET=""
EMAIL_FROM="noreply@rakoon.io"
EMAIL_FROM_NAME="Artemis"
# URL publique de l'application (liens dans les e-mails)
APP_URL="http://localhost:3000"

# Intégration IA Mistral (génération de tickets depuis un texte collé) - optionnel.
# La fonctionnalité « Créer depuis un texte » se désactive proprement si la clé
# est absente. La clé est lue CÔTÉ SERVEUR UNIQUEMENT (jamais exposée au client).
# Obtenir une clé : https://console.mistral.ai/ - NE JAMAIS committer une vraie valeur.
MISTRAL_API_KEY=""
# Modèle utilisé (défaut : mistral-medium-3.5 ; pin daté : mistral-medium-3-5-26-04)
MISTRAL_MODEL="mistral-medium-3.5"
# Mode d'exécution : par défaut le traitement par lot (Batch API), ~50 % moins cher
# mais ASYNCHRONE (téléversement + job + attente). Mettre "false" pour un appel
# synchrone (réponse immédiate, coût plein).
MISTRAL_USE_BATCH="true"
# Budget d'attente d'un job batch avant abandon, en millisecondes (défaut 120000).
MISTRAL_BATCH_TIMEOUT_MS="120000"
# Surcharge de l'endpoint chat completions (tests ; défaut API Mistral). Sert aussi
# de base aux endpoints Files/Batch (l'origine de cette URL est réutilisée).
MISTRAL_API_URL="https://api.mistral.ai/v1/chat/completions"

# Rakoon Tracker — variables d'environnement (modèle). Copier en `.env` et compléter.

# Base de données PostgreSQL (Prisma)
DATABASE_URL="postgresql://tracker:tracker@localhost:5432/rakoon_tracker?schema=public"

# Auth.js
AUTH_SECRET="générer avec: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Stockage S3-compatible des pièces jointes (MinIO en local) — optionnel
# (la fonctionnalité se désactive proprement si non renseigné)
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="rakoon-tracker-attachments"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_REGION="us-east-1"
